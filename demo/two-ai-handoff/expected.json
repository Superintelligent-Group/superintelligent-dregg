    "captp_delivered_turn_assembled",
    "captp_delivered_introducer_sig_verifies",
    "captp_delivered_sender_sig_verifies",
    "captp_delivered_sender_pk_matches_cert_recipient",
    "captp_delivered_introducer_pk_matches_cert_introducer",

    "sovereign_witness_signed_by_alice",
    "sovereign_witness_self_verifies",
    "sovereign_witness_signing_message_matches_canonical_layout",

    "slot_caveat_first_write_accepted",
    "slot_caveat_renewal_accepted",

    "bilateral_bundle_verifies_for_alice_and_bob",
