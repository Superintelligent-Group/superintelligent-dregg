{
  "name": "@pyana/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the pyana distributed authorization system",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "pyana",
    "authorization",
    "macaroon",
    "stark",
    "merkle",
    "zero-knowledge",
    "wasm"
  ],
  "license": "MIT",
  "peerDependencies": {
    "pyana-wasm": ">=0.1.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "@types/node": "^20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pyana/sdk-ts"
  }
}
